{
  "firestore": {
    "database": "(default)",
    "location": "asia-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "src",
        "firebase-debug.log",
        "*.local"
      ],
      "predeploy": ["npm run build"],
      "runtime": "nodejs24"
    }
  ]
}
